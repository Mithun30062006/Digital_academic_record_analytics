{
  "version": 2,

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://digital-academic-record-analytics.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://digital-academic-record-analytics.onrender.com/uploads/:path*"
    }
  ],

  "routes": [
    {
      "src": "/(css|js|img)/(.*)",
      "dest": "frontend/$1/$2"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "frontend/$1"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}